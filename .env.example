# Anthropic credentials
ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_MODEL_FALLBACKS=claude-sonnet-4-5-20250929,claude-sonnet-4-20250514,claude-3-7-sonnet-20250219,claude-3-5-sonnet-20241022,claude-3-5-sonnet-20240620

# Jira MCP used by the planning agent only.
JIRA_MCP_COMMAND=npx
JIRA_MCP_ARGS_JSON=["-y","jira-mcp"]
JIRA_MCP_TOOL=get_issue
JIRA_MCP_ISSUE_KEY_ARGUMENT=issueIdOrKey
JIRA_MCP_TIMEOUT_MS=20000

# Jira credentials consumed by your chosen Jira MCP server.
# Confirm exact names with the MCP package documentation.
JIRA_INSTANCE_URL=https://hiteshgetbit.atlassian.net
JIRA_USER_EMAIL=your-atlassian-email@example.com
JIRA_API_KEY=your-jira-api-token

# Cypress QA agent (optional overrides)
# CYPRESS_CACHE_FOLDER=/tmp/cypress-cache
# CYPRESS_TIMEOUT_MS=180000
# CYPRESS_BROWSER=electron
